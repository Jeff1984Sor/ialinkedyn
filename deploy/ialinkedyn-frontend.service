[Unit]
Description=IALinkedyn Frontend (Next.js)
After=network.target

[Service]
User=financeiro
Group=financeiro
WorkingDirectory=/home/financeiro/ialinkedyn/frontend
Environment=NODE_ENV=production
Environment=PORT=3021
ExecStart=/home/financeiro/ialinkedyn/frontend/node_modules/.bin/next start -p 3021
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
