[Unit]
Description=IALinkedyn API (FastAPI/gunicorn)
After=network.target postgresql.service

[Service]
User=financeiro
Group=financeiro
WorkingDirectory=/home/financeiro/ialinkedyn
ExecStart=/home/financeiro/ialinkedyn/.venv/bin/gunicorn -c deploy/gunicorn_conf.py app.main:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
