# ============================================================
# IALinkedyn — exemplo de configuração
# Copie para ".env" (NUNCA versionar o .env real) e preencha.
# No prod1, o .env real fica só no servidor, fora do git.
# ============================================================

# --- App ---
APP_NAME=IALinkedyn
ENVIRONMENT=development          # development | production
# Origens permitidas no CORS (frontend). Separadas por vírgula.
CORS_ORIGINS=http://localhost:3021,https://ialinkedyn.mayacorp.com.br

# --- Banco de dados (PostgreSQL no prod1) ---
# Formato SQLAlchemy + psycopg v3.
DATABASE_URL=postgresql+psycopg://ialinkedyn_user:TROQUE_A_SENHA@localhost:5432/ialinkedyn

# --- Autenticação (JWT simples, single-tenant) ---
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=troque-por-um-segredo-forte
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Criptografia de tokens de terceiros (Fernet) ---
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=troque-por-uma-chave-fernet-base64

# --- IA (Google Gemini) ---
GEMINI_API_KEY=coloque-sua-chave-aqui
GEMINI_MODEL=gemini-2.5-flash

# --- Camada de conexão LinkedIn ---
# mock  = provedor simulado (desenvolvimento, sem custo)
# unipile = provedor real (preencher credenciais abaixo)
LINKEDIN_PROVIDER=mock
UNIPILE_DSN=
UNIPILE_API_KEY=
