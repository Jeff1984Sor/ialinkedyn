# ============================================================
# IALinkedyn — configuração de INFRAESTRUTURA apenas.
#
# ⚠️ As chaves de produto (Gemini, Unipile) e a escolha do provedor
#    NÃO ficam aqui — são configuradas no PAINEL, em "Conexões",
#    e salvas criptografadas (Fernet) no banco.
#
# Copie para ".env" (NUNCA versionar o .env real) e preencha.
# ============================================================

# --- App ---
APP_NAME=IALinkedyn
ENVIRONMENT=development          # development | production
# Origens permitidas no CORS (frontend). Separadas por vírgula.
CORS_ORIGINS=http://localhost:3021

# --- Banco de dados (PostgreSQL no prod1) ---
DATABASE_URL=postgresql+psycopg://ialinkedyn_user:TROQUE_A_SENHA@localhost:5432/ialinkedyn

# --- Autenticação (JWT simples, single-tenant) ---
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=troque-por-um-segredo-forte
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Criptografia dos segredos guardados no banco (Fernet) ---
# ⚠️ Se perder/trocar esta chave, as chaves de API salvas no painel
#    precisarão ser digitadas de novo.
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=troque-por-uma-chave-fernet-base64
